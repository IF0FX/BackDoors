-- Ваши ID администраторов (для отображения статуса)
local ADMIN_IDS = {[10667534302] = true, [389151777] = true}
local player = game:GetService("Players").LocalPlayer
local isAdmin = ADMIN_IDS[player.UserId] or false

-- Поиск RemoteEvent (бекдора)
local remote = nil
for _, v in pairs(game:GetService("ReplicatedStorage"):GetChildren()) do
    if v:IsA("RemoteEvent") and v.Name:match("^SysUpd_[0-9a-f]+$") then
        remote = v
        break
    end
end

if not remote then
    warn("❌ Бекдор не найден на сервере!")
    return
end

-- Если игрок не админ, показываем предупреждение и выходим
if not isAdmin then
    local notify = Instance.new("ScreenGui")
    local frame = Instance.new("Frame")
    local label = Instance.new("TextLabel")
    frame.Size = UDim2.new(0, 300, 0, 100)
    frame.Position = UDim2.new(0.5, -150, 0.5, -50)
    frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
    label.Text = "⛔ У вас нет прав доступа к бекдору!"
    label.Size = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,0,0)
    label.Parent = frame
    frame.Parent = notify
    notify.Parent = player:WaitForChild("PlayerGui")
    wait(3)
    notify:Destroy()
    return
end

