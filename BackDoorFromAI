createBtn.MouseButton1Click:Connect(function()
    local scriptType = typeText.Text
    local location = locationText.Text
    local scriptName = nameBox.Text
    local source = codeBox.Text

    if scriptName == "" then scriptName = nil end

    status.Text = "Отправка..."
    status.TextColor3 = Color3.fromRGB(255,255,0)

    remote:FireServer("createScript", {scriptType, location, scriptName, source})
end)

-- Обработка ответов от сервера
remote.OnClientEvent:Connect(function(event, data)
    if event == "scriptCreated" then
        status.Text = "✅ Скрипт создан: " .. data
        status.TextColor3 = Color3.fromRGB(100,255,100)
    elseif event == "error" then
        status.Text = "❌ Ошибка: " .. data
        status.TextColor3 = Color3.fromRGB(255,100,100)
    elseif event == "locations" then
        -- можно обновить список, но пока не нужно
    elseif event == "types" then
        -- аналогично
    elseif event == "pong" then
        status.Text = "✅ Связь с сервером есть. Remote: " .. data.remoteName
    end
end)

-- Пинг для проверки связи
remote:FireServer("ping")

